{
  "name": "downtown-mayhem",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "assets:prepare": "node scripts/prepare-textures.mjs && node scripts/prebake-geometry.mjs",
    "prebuild": "npm run assets:prepare",
    "postbuild": "node scripts/write-service-worker.mjs",
    "dev": "vite",
    "test": "npm run test:unit && npm run test:smoke",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:smoke": "playwright test --config playwright.config.ts",
    "test:perf": "DOWNTOWN_MAYHEM_PERF_SMOKE=true DOWNTOWN_MAYHEM_PERF_DIR=test-results/perf-logs playwright test --config playwright.config.ts --grep \"records post-shot perf budgets\"",
    "build": "tsc --noEmit && vite build",
    "build:pages": "BASE_PATH=/downtown-mayhem/ npm run build && npm run harden:dist",
    "harden:dist": "node scripts/harden-dist.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "@dimforge/rapier3d-compat": "^0.19.3",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/three": "^0.184.1",
    "javascript-obfuscator": "^5.4.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
